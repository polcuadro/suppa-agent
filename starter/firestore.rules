rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═════════════ HELPERS ═════════════
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.token.email));
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/authorizedUsers/$(request.auth.token.email)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ═════════════ AUTHORIZED USERS ═════════════
    match /authorizedUsers/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ═════════════ USERS (profile) ═════════════
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) && isAuthorized();
    }

    // ═════════════ CHATS ═════════════
    match /chats/{chatId} {
      allow read: if isAuthorized() &&
        (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthorized() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthorized() &&
        resource.data.ownerId == request.auth.uid;

      match /messages/{msgId} {
        allow read: if isAuthorized() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.ownerId == request.auth.uid
          || isAdmin()
        );
        // Writes only via Cloud Function (admin SDK bypasses rules)
        allow write: if false;
      }
    }

    // ═════════════ TESTER LOGS ═════════════
    match /testerLogs/{logId} {
      allow read: if isAuthorized();
      allow write: if false;
    }
  }
}
